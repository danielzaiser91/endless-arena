rules_version = '2';

// Leaderboard rules (implementation.md §11): public read (needed for the live top-100 query),
// writes only to one's own doc, schema-validated, bestLevel monotonically non-decreasing.
// No anti-cheat beyond this — documented as a toy leaderboard for a free game.
service cloud.firestore {
  match /databases/{database}/documents {
    match /players/{uid} {
      allow read: if true;
      allow create: if isOwner(uid) && isValidPlayerDoc(request.resource.data);
      allow update: if isOwner(uid)
        && isValidPlayerDoc(request.resource.data)
        && request.resource.data.bestLevel >= resource.data.bestLevel;
      allow delete: if false;
    }
  }

  function isOwner(uid) {
    return request.auth != null && request.auth.uid == uid;
  }

  function isValidPlayerDoc(data) {
    return data.keys().hasOnly(['name', 'bestLevel', 'kills', 'ascensions', 'classId', 'updatedAt'])
      && data.name is string && data.name.size() >= 1 && data.name.size() <= 16
      && data.bestLevel is int && data.bestLevel >= 0
      && data.kills is int && data.kills >= 0
      && data.ascensions is int && data.ascensions >= 0
      && (data.classId == null || data.classId is string)
      && data.updatedAt == request.time;
  }
}
